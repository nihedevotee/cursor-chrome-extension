{
  "manifest_version": 3,
  "name": "Cursor Trail",
  "version": "1.0",
  "description": "Purple cursor trail effect",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}